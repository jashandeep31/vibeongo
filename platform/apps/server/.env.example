# Vibeongo platform server configuration
#
# Copy this file to `.env` and replace every placeholder before starting the
# server. Do not commit `.env`, private keys, tokens, or production credentials.
# Unless a comment says otherwise, every variable below is required by the
# validation schema in `src/lib/env.ts`.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Port on which the Express HTTP and WebSocket server listens.
PORT=4000

# Runtime mode. Must be one of: development, production, or test.
# Development enables extra error details and uses test-mode payments.
NODE_ENV=development

# Public URL of the Next.js web application. No trailing slash.
# Used for redirects, payment return URLs, and links returned by the AI tools.
FRONTEND_URL=http://localhost:3000

# Public URL of this API server. Include the scheme and port when needed, but no
# trailing slash. GitHub OAuth callbacks and workspace installers use this URL.
BACKEND_URL=http://localhost:8000

# Parent hostname used when setting the authentication cookie. Do not include a
# scheme, port, path, or leading dot. Use `localhost` for local development.
DOMAIN=localhost

# Comma-separated list of browser origins allowed by CORS. Each origin must
# include its scheme and port (when non-standard). Do not add URL paths.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# Database and application secrets
# -----------------------------------------------------------------------------

# PostgreSQL connection string used by Drizzle and node-postgres.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibeongo

# Secret used to sign and verify login session JWTs. Generate a strong random
# value, for example with: openssl rand -base64 32
JWT_SECRET=replace-with-a-long-random-secret

# Base64-encoded 32-byte key used by AES-256-CCM to encrypt project file data.
# Generate it with: openssl rand -base64 32
# Keep this key stable; changing it makes existing encrypted data unreadable.
ENCRYPTION_KEY=replace-with-a-base64-encoded-32-byte-key

# -----------------------------------------------------------------------------
# GitHub OAuth and GitHub App
# -----------------------------------------------------------------------------

# OAuth App credentials used for "Continue with GitHub" authentication.
# Set the OAuth callback URL in GitHub to:
#   <BACKEND_URL>/api/v1/auth/github/callback
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Numeric App ID of the GitHub App used for repository webhooks and automation.
GITHUB_APP_ID=123456

# Secret configured for the GitHub App webhook. The webhook endpoint is:
#   <BACKEND_URL>/api/v1/github-app/webhook
GITHUB_WEBHOOK_SECRET=replace-with-github-webhook-secret

# The GitHub App private key is not an environment variable. Download the PEM
# key from GitHub and save it as `vibeongo.pem` in this app's working directory.

# -----------------------------------------------------------------------------
# Workspace proxy
# -----------------------------------------------------------------------------

# Shared bearer token used to authenticate internal requests to the proxy
# service. Configure the same token on the proxy server.
# Generate a value with: openssl rand -base64 32
PROXY_SERVER_TOKEN=replace-with-a-long-random-token

# Development workspace-preview domain suffix. Include the leading dot and
# configure wildcard DNS/TLS for it, for example `*.workspace.example.com`.
# Production currently uses region-specific domains defined in the source code.
PROXY_DOMAIN=.workspace.example.com

# Base URL of the workspace proxy API, including scheme and optional port.
# This is required by the current schema but is not directly read by the
# platform server yet; the core runtime uses a variable with the same name.
PROXY_SERVER_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Cloud compute providers
# -----------------------------------------------------------------------------

# AWS IAM access keys used to create and terminate EC2 instances and read
# CloudWatch metrics. Grant only the EC2/CloudWatch permissions the app needs.
# The server currently supports us-east-1 and ap-south-1.
AWS_EC2_ACCESS_KEY_ID=replace-with-aws-access-key-id
AWS_EC2_ACCESS_KEY_SECRET=replace-with-aws-secret-access-key

# DigitalOcean personal access token used to manage Droplets and read bandwidth
# metrics. Create a token with the minimum required read/write scopes.
DIGITALOCEAN_API_KEY=replace-with-digitalocean-api-token

# -----------------------------------------------------------------------------
# Email (Amazon SES)
# -----------------------------------------------------------------------------

# AWS IAM credentials used only for sending email through Amazon SES in
# us-east-1. The sender identities must also be verified in that SES region.
AWS_SES_ACCESS_KEY_ID=replace-with-ses-access-key-id
AWS_SES_SECRET_KEY=replace-with-ses-secret-access-key

# -----------------------------------------------------------------------------
# AI providers
# -----------------------------------------------------------------------------
# API key for the AI gateway used by supported coding-agent integrations.
# It is required by the schema but is not directly read by server code yet.
AI_GATEWAY_API_KEY=replace-with-ai-gateway-api-key

# -----------------------------------------------------------------------------
# Payments (Dodo Payments)
# -----------------------------------------------------------------------------

# Product ID charged when a user adds funds. Use a test-mode product while
# NODE_ENV=development and the matching live-mode product in production.
DODO_PAYMENT_PRODUCT_ID=replace-with-dodo-product-id

# Dodo Payments API bearer token. Its environment must match NODE_ENV.
DODO_PAYMENT_BEARER_TOKEN=replace-with-dodo-api-token

# Signing secret used to verify requests sent to `/v1/webhook/dodo`.
DODO_PAYMENTS_WEBHOOK_SECRET=replace-with-dodo-webhook-secret

# Percentage markup added to the underlying compute cost. The schema accepts a
# number from 10 through 100. For example, 20 means a 20% markup.
# Keep the existing `PRECENTAGE` spelling; it is the name expected by the code.
PROFIT_PRECENTAGE=20

# -----------------------------------------------------------------------------
# Error monitoring
# -----------------------------------------------------------------------------

# Sentry project DSN. Sentry is enabled only when NODE_ENV=production.
# Use the full HTTPS DSN copied from the Sentry project settings.
DSN=https://public-key@your-sentry-host.example/your-project-id
